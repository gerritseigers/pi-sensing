[Unit]
Description=Pi Edge Sensing: Azure uploader
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=staldemo
WorkingDirectory=/home/staldemo/Projects/pi-sensing
Environment=PYTHONUNBUFFERED=1
EnvironmentFile=/home/staldemo/Projects/pi-sensing/.env
ExecStart=/home/staldemo/Projects/pi-sensing/venv/bin/python /home/staldemo/Projects/pi-sensing/src/uploader.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
