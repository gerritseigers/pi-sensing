[Unit]
Description=Pi Edge Sensing: Azure uploader
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=%u
WorkingDirectory=%h/Projects/pi-sensing
Environment=PYTHONUNBUFFERED=1
EnvironmentFile=%h/Projects/pi-sensing/.env
ExecStart=%h/Projects/pi-sensing/venv/bin/python %h/Projects/pi-sensing/src/uploader.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
